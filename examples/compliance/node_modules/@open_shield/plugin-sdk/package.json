{
  "name": "@open_shield/plugin-sdk",
  "version": "1.0.2",
  "description": "OpenShield Dashboard Plugin SDK — types, helpers, and utilities for building plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
