    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YordanOpenShield/openshield-dashboard",
    "directory": "packages/plugin-sdk"
  },
  "keywords": ["openshield", "plugin", "sdk", "dashboard"],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YordanOpenShield/openshield-dashboard/issues"
  },
  "homepage": "https://github.com/YordanOpenShield/openshield-dashboard/tree/main/packages/plugin-sdk",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
