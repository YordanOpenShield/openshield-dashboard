{
  "name": "@open_shield/plugin-builder",
  "version": "1.0.1",
  "description": "OpenShield Dashboard Plugin Builder — compile and package plugins for the dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "plugin-builder": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YordanOpenShield/openshield-dashboard",
    "directory": "packages/plugin-builder"
  },
  "keywords": ["openshield", "plugin", "builder", "cli"],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YordanOpenShield/openshield-dashboard/issues"
  },
  "homepage": "https://github.com/YordanOpenShield/openshield-dashboard/tree/main/packages/plugin-builder",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
